<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0B0B10" />
  <meta name="description" content="NEON DUEL — Duelos 1v1 en tiempo real. Partidas cortas, ranking y estilo neon violeta." />
  <title>NEON DUEL — Multiplayer 1v1</title>
  <style>
    :root{
      --bg:#0B0B10;
      --surface:#12121A;
      --text:#FFFFFF;
      --muted:#B5B5C7;
      --neon:#8B5CF6;
      --glow:#A78BFA;
      --ok:#22C55E;
      --shadow: 0 0 22px rgba(167,139,250,.35), 0 0 60px rgba(139,92,246,.18);
      --radius: 18px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Noto Sans", "Helvetica Neue", sans-serif;
      color:var(--text);
      background: radial-gradient(900px 500px at 70% 20%, rgba(139,92,246,.22), transparent 60%),
                  radial-gradient(900px 500px at 20% 80%, rgba(167,139,250,.18), transparent 55%),
                  var(--bg);
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
    }
    .wrap{width:min(980px, 100%);}

    .card{
      background: linear-gradient(180deg, rgba(18,18,26,.92), rgba(18,18,26,.72));
      border: 1px solid rgba(139,92,246,.35);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow:hidden;
      position:relative;
    }

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:16px 20px;
      border-bottom:1px solid rgba(139,92,246,.22);
      background: rgba(11,11,16,.25);
    }
    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      letter-spacing:.5px;
    }
    .logo{
      width:44px; height:44px;
      border-radius:14px;
      background: radial-gradient(circle at 30% 30%, rgba(167,139,250,.95), rgba(139,92,246,.55) 45%, rgba(139,92,246,.15) 75%);
      box-shadow: 0 0 18px rgba(167,139,250,.35);
      position:relative;
    }
    .logo:after{
      content:"";
      position:absolute;
      inset:10px;
      border:1px solid rgba(255,255,255,.25);
      border-radius:10px;
      filter: blur(.2px);
    }
    .brand h1{
      margin:0;
      font-size:16px;
      font-weight:800;
    }
    .badge{
      font-size:12px;
      color:var(--muted);
      border:1px solid rgba(181,181,199,.25);
      padding:6px 10px;
      border-radius:999px;
      background: rgba(255,255,255,.04);
    }

    .hero{
      display:grid;
      grid-template-columns: 1.2fr .8fr;
      gap:18px;
      padding:28px 22px 22px;
    }
    @media (max-width: 860px){
      .hero{grid-template-columns:1fr;}
    }

    .title{
      margin:0 0 10px 0;
      font-size:42px;
      line-height:1.05;
      font-weight:900;
      letter-spacing:.8px;
    }
    .title span{
      color: var(--glow);
      text-shadow: 0 0 22px rgba(167,139,250,.28);
    }
    .subtitle{
      margin:0 0 18px 0;
      color:var(--muted);
      font-size:16px;
      line-height:1.55;
      max-width: 60ch;
    }

    .ctaRow{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      margin-top:10px;
    }
    .btn{
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:12px 16px;
      border-radius:14px;
      border:1px solid rgba(139,92,246,.45);
      background: rgba(139,92,246,.12);
      color:var(--text);
      text-decoration:none;
      font-weight:700;
      transition: transform .12s ease, box-shadow .12s ease, background .12s ease;
      box-shadow: 0 0 16px rgba(167,139,250,.14);
      user-select:none;
    }
    .btn:hover{ transform: translateY(-1px); box-shadow: 0 0 24px rgba(167,139,250,.20); }
    .btn:active{ transform: scale(.98); }

    .btnSecondary{
      border:1px solid rgba(181,181,199,.25);
      background: rgba(255,255,255,.04);
      color: var(--muted);
      box-shadow:none;
    }

    .panel{
      background: rgba(0,0,0,.18);
      border:1px solid rgba(139,92,246,.18);
      border-radius: var(--radius);
      padding:16px;
    }
    .panel h3{
      margin:0 0 10px 0;
      font-size:14px;
      color:var(--muted);
      font-weight:800;
      letter-spacing:.5px;
      text-transform:uppercase;
    }
    .list{
      display:grid;
      gap:10px;
      margin:0;
      padding:0;
      list-style:none;
    }
    .item{
      display:flex;
      gap:12px;
      align-items:flex-start;
      padding:10px 10px;
      border-radius:14px;
      background: rgba(255,255,255,.03);
      border:1px solid rgba(255,255,255,.06);
    }
    .dot{
      width:10px; height:10px;
      border-radius:999px;
      background: var(--neon);
      box-shadow: 0 0 16px rgba(167,139,250,.35);
      margin-top:4px;
      flex:0 0 auto;
    }
    .item b{ display:block; font-size:14px; }
    .item span{ display:block; color:var(--muted); font-size:13px; margin-top:2px; line-height:1.35; }

    .footer{
      display:flex;
      justify-content:space-between;
      gap:10px;
      flex-wrap:wrap;
      padding:16px 22px 22px;
      border-top:1px solid rgba(139,92,246,.22);
      color: var(--muted);
      font-size:13px;
    }
    .footer a{ color: var(--glow); text-decoration:none; }
    .footer a:hover{ text-decoration:underline; }

    /* watermark */
    .wm{
      position:absolute;
      right:-80px;
      top:-120px;
      width:420px;
      height:420px;
      border-radius:999px;
      border:1px solid rgba(139,92,246,.22);
      filter: blur(.2px);
      opacity:.35;
      background: radial-gradient(circle at 30% 30%, rgba(167,139,250,.25), rgba(139,92,246,.08) 55%, transparent 70%);
      pointer-events:none;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <div class="wm"></div>

      <div class="topbar">
        <div class="brand">
          <div class="logo" aria-hidden="true"></div>
          <div>
            <h1>NEON DUEL</h1>
            <div class="badge">Multiplayer 1v1 · Ranked</div>
          </div>
        </div>
        <div class="badge">Minimal Neon · Violet Edition</div>
      </div>

      <div class="hero">
        <div>
          <h2 class="title">Duelos <span>1v1</span> en tiempo real.</h2>
          <p class="subtitle">
            Partidas cortas, intensas y adictivas. Competí contra jugadores reales, subí en el ranking
            y dominá el timing. Sin vueltas: entrás, jugás, ganás… o pedís revancha.
          </p>

          <div class="ctaRow">
            <!-- CAMBIAR: tu link real de Google Play cuando lo tengas -->
            <a class="btn" href="https://play.google.com/store/apps/details?id=TU.PACKAGE.NAME" target="_blank" rel="noopener">
              ▶ Descargar en Google Play
            </a>

            <!-- CAMBIAR: link a tu política cuando la tengas -->
            <a class="btn btnSecondary" href="https://tu-dominio.com/privacy" target="_blank" rel="noopener">
              Política de Privacidad
            </a>

            <!-- CAMBIAR: tu email -->
            <a class="btn btnSecondary" href="mailto:soporte@tudominio.com">
              Contacto
            </a>
          </div>
        </div>

        <div class="panel">
          <h3>Características</h3>
          <ul class="list">
            <li class="item">
              <div class="dot"></div>
              <div>
                <b>Online 1v1</b>
                <span>Multiplayer en tiempo real con partidas rápidas.</span>
              </div>
            </li>
            <li class="item">
              <div class="dot"></div>
              <div>
                <b>Ranked</b>
                <span>MMR competitivo y progreso por liga.</span>
              </div>
            </li>
            <li class="item">
              <div class="dot"></div>
              <div>
                <b>Minijuegos de habilidad</b>
                <span>Reflejos, precisión y timing. Cero relleno.</span>
              </div>
            </li>
            <li class="item">
              <div class="dot"></div>
              <div>
                <b>Estilo Neon Violeta</b>
                <span>Interfaz minimal premium con identidad fuerte.</span>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <div class="footer">
        <div>© <span id="year"></span> NEON DUEL · Todos los derechos reservados.</div>
        <div>
          <a href="mailto:soporte@tudominio.com">soporte@tudominio.com</a>
          ·
          <a href="https://tu-dominio.com/privacy" target="_blank" rel="noopener">Privacidad</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById("year").textContent = new Date().getFullYear();
  </script>
</body>
</html>
